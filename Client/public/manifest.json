{
  "manifest_version": 3,
  "name": "webGather",
  "version": "1.0",

  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "sidePanel",
    "downloads",
    "storage"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "action": {
    "default_title": "webGather"
  },

  "background": {
    "service_worker": "background.js"
  },

  "side_panel": {
    "default_path": "index.html"
  }
}